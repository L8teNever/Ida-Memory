# Kopieren nach ".env" und ausfuellen. ".env" NIEMALS committen.

# --- Absicherung des MCP-Endpunkts ---
# Langes zufaelliges Geheimnis, das jede KI beim Verbinden mitschicken muss.
# Erzeugen z.B. mit: openssl rand -hex 32
MCP_AUTH_TOKEN=hier-langes-zufaelliges-token-eintragen

# Lokaler Port, den docker-compose auf 127.0.0.1 published (siehe docker-compose.yml).
# Standard 4568, damit es neben Ida-Untis (8000) und Ida-Telegram (4567) auf
# demselben Server laufen kann.
MCP_PORT=4568

# Maximale Anzahl Entities, die search_nodes pro Aufruf zurueckgibt. Haelt
# das Gedaechtnis auch bei tausenden Eintraegen noch guenstig -- ein zu
# allgemeiner Suchbegriff liefert sonst irgendwann hunderte Treffer und damit
# unnoetig viele Tokens. Bei zu vielen Treffern zeigt die Antwort einen
# Hinweis, dass die Suche praezisiert werden sollte.
SEARCH_RESULT_LIMIT=30

# --- Nur fuer docker-compose (Image-Referenz aus GHCR) ---
# Dein GitHub-Benutzername/-Organisation in Kleinbuchstaben.
GITHUB_OWNER=l8tenever
IMAGE_TAG=latest
